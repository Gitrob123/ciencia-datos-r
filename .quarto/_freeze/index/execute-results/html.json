}\n\n```\nThe following object is masked from 'package:ggplot2':\n\n    margin\n```\n\n\n:::\n\n```{.r .cell-code}\nset.seed(123)\n\ntrain_index <- sample(1:nrow(titanic), 0.7*nrow(titanic))\ntrain <- titanic[train_index, ]\ntest  <- titanic[-train_index, ]\n\nrf_model <- randomForest(\n  Survived ~ Class + Sex + Age,\n  data = train,\n  ntree = 200,\n  importance = TRUE\n)\n\nrf_model\n```\n\n::: {.cell-output .cell-output-stdout}\n\n```\n\nCall:\n randomForest(formula = Survived ~ Class + Sex + Age, data = train,      ntree = 200, importance = TRUE) \n               Type of random forest: classification\n                     Number of trees: 200\nNo. of variables tried at each split: 1\n\n        OOB estimate of  error rate: 21.17%\nConfusion matrix:\n      No Yes class.error\nNo  1030  25  0.02369668\nYes  301 184  0.62061856\n```\n\n\n:::\n:::\n\n\n------------------------------------------------------------------------\n\n## 📈 4. Importancia de Variables\n\n\n::: {.cell}\n\n```{.r .cell-code}\nimportance_df <- as.data.frame(importance(rf_model))\nimportance_df$Variable <- rownames(importance_df)\n\nplot_ly(\n  importance_df,\n  x = ~MeanDecreaseGini,\n  y = ~reorder(Variable, MeanDecreaseGini),\n  type = \"bar\",\n  orientation = \"h\"\n) %>%\n  layout(\n    title = \"Importancia de Variables\",\n    xaxis = list(title = \"Mean Decrease Gini\"),\n    yaxis = list(title = \"\")\n  )\n```\n\n::: {.cell-output-display}\n\n```{=html}\n<div class=\"plotly html-widget html-fill-item\" id=\"htmlwidget-00200ee364db02f27001\" style=\"width:100%;height:464px;\"></div>\n<script type=\"application/json\" data-for=\"htmlwidget-00200ee364db02f27001\">{\"x\":{\"visdat\":{\"149872213969\":[\"function () \",\"plotlyVisDat\"]},\"cur_data\":\"149872213969\",\"attrs\":{\"149872213969\":{\"x\":{},\"y\":{},\"orientation\":\"h\",\"alpha_stroke\":1,\"sizes\":[10,100],\"spans\":[1,20],\"type\":\"bar\"}},\"layout\":{\"margin\":{\"b\":40,\"l\":60,\"t\":25,\"r\":10},\"title\":\"Importancia de Variables\",\"xaxis\":{\"domain\":[0,1],\"automargin\":true,\"title\":\"Mean Decrease Gini\"},\"yaxis\":{\"domain\":[0,1],\"automargin\":true,\"title\":\"\",\"type\":\"category\",\"categoryorder\":\"array\",\"categoryarray\":[\"Age\",\"Class\",\"Sex\"]},\"hovermode\":\"closest\",\"showlegend\":false},\"source\":\"A\",\"config\":{\"modeBarButtonsToAdd\":[\"hoverclosest\",\"hovercompare\"],\"showSendToCloud\":false},\"data\":[{\"x\":[41.240593137508398,93.220592485959187,3.2013386229728824],\"y\":[\"Class\",\"Sex\",\"Age\"],\"orientation\":\"h\",\"type\":\"bar\",\"marker\":{\"color\":\"rgba(31,119,180,1)\",\"line\":{\"color\":\"rgba(31,119,180,1)\"}},\"error_y\":{\"color\":\"rgba(31,119,180,1)\"},\"error_x\":{\"color\":\"rgba(31,119,180,1)\"},\"xaxis\":\"x\",\"yaxis\":\"y\",\"frame\":null}],\"highlight\":{\"on\":\"plotly_click\",\"persistent\":false,\"dynamic\":false,\"selectize\":false,\"opacityDim\":0.20000000000000001,\"selected\":{\"opacity\":1},\"debounce\":0},\"shinyEvents\":[\"plotly_hover\",\"plotly_click\",\"plotly_selected\",\"plotly_relayout\",\"plotly_brushed\",\"plotly_brushing\",\"plotly_clickannotation\",\"plotly_doubleclick\",\"plotly_deselect\",\"plotly_afterplot\",\"plotly_sunburstclick\"],\"base_url\":\"https://plot.ly\"},\"evals\":[],\"jsHooks\":[]}</script>\n```\n\n:::\n:::\n\n\n------------------------------------------------------------------------\n\n## 🎯 5. Evaluación del Modelo\n\n\n::: {.cell}\n\n```{.r .cell-code}\npred <- predict(rf_model, newdata = test)\n\nconf_matrix <- table(Predicho = pred,\n                     Real = test$Survived)\n\ndatatable(as.data.frame(conf_matrix),\n          caption = \"Matriz de Confusión\")\n```\n\n::: {.cell-output-display}\n\n```{=html}\n<div class=\"datatables html-widget html-fill-item\" id=\"htmlwidget-9670dfccecf944e6179c\" style=\"width:100%;height:auto;\"></div>\n<script type=\"application/json\" data-for=\"htmlwidget-9670dfccecf944e6179c\">{\"x\":{\"filter\":\"none\",\"vertical\":false,\"caption\":\"<caption>Matriz de Confusión<\\/caption>\",\"data\":[[\"1\",\"2\",\"3\",\"4\"],[\"No\",\"Yes\",\"No\",\"Yes\"],[\"No\",\"No\",\"Yes\",\"Yes\"],[432,3,154,72]],\"container\":\"<table class=\\\"display\\\">\\n  <thead>\\n    <tr>\\n      <th> <\\/th>\\n      <th>Predicho<\\/th>\\n      <th>Real<\\/th>\\n      <th>Freq<\\/th>\\n    <\\/tr>\\n  <\\/thead>\\n<\\/table>\",\"options\":{\"columnDefs\":[{\"className\":\"dt-right\",\"targets\":3},{\"orderable\":false,\"targets\":0}],\"order\":[],\"autoWidth\":false,\"orderClasses\":false}},\"evals\":[],\"jsHooks\":[]}</script>\n```\n\n:::\n:::\n\n\n------------------------------------------------------------------------\n\n## 🧠 Conclusiones\n\n-   Sexo y Clase son variables clave.\n-   Random Forest tiene buena capacidad predictiva.\n-   La interactividad mejora el análisis.\n\n------------------------------------------------------------------------\n\n## 🚀 Tecnologías usadas\n\n-   R\n-   Quarto\n-   Random Forest\n-   Plotly\n-   GitHub Pages\n",
